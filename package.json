{
  "name": "framer-extract",
  "version": "0.1.0",
  "description": "Extract and regenerate code from Framer sites",
  "type": "module",
  "bin": {
    "framer-extract": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "commander": "^12.1.0",
    "playwright": "^1.48.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/sharp": "^0.31.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
