{
  "name": "framer-extract",
  "version": "0.1.0",
  "description": "Extract and regenerate code from Framer sites",
  "type": "module",
  "bin": {
    "framer-extract": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "css-tree": "^3.0.0",
    "playwright": "^1.48.0",
    "postcss": "^8.4.47"
  },
  "devDependencies": {
    "@types/css-tree": "^2.3.8",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
